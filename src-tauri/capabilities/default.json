{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the ToolDock main window",
  "windows": ["main", "color-picker-*", "region-selector-*"],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister-all",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://routemarket.ai/?utm_source=tooldock&utm_medium=desktop_app&utm_campaign=sidebar_promo&utm_content=routemarket"
        },
        {
          "url": "https://tools.routemarket.ai/?utm_source=tooldock&utm_medium=desktop_app&utm_campaign=sidebar_promo&utm_content=tools"
        }
      ]
    },
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "$VIDEO/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$TEMP/**"
        }
      ]
    },
    "opener:allow-reveal-item-in-dir"
  ]
}
